// 1. НАЛАШТУВАННЯ ПІДКЛЮЧЕННЯ
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. ТАБЛИЦЯ КОРИСТУВАЧІВ (Для входу в систему)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// 3. ТАБЛИЦЯ ТВАРИНОК (Повністю під твою анкету "Шукаю дім")
model Pet {
  id            String   @id @default(uuid())
  name          String?
  type          String
  gender        String
  age           String
  sterilization String
  vaccination   String
  region        String
  city          String
  description   String
  photos        String   @default("[]")
  status        String   @default("pending")
  category      String   @default("adoption") // НОВЕ ПОЛЕ: "adoption" або "lost"
  createdAt     DateTime @default(now())
}