// 1. ОЦЕ ТА САМА ШАПКА, ЯКА ЗНИКЛА (Підключення до БД)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. ТАБЛИЦЯ КОРИСТУВАЧІВ
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// 3. ТАБЛИЦЯ ТВАРИНОК (з твоїми новими полями для модерації)
model Pet {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  location    String?
  imageUrl    String?
  
  // Поля для адмінки:
  status      String   @default("pending") 
  authorId    Int      @default(0)         
}