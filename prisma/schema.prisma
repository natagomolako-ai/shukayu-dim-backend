// 1. НАЛАШТУВАННЯ ПІДКЛЮЧЕННЯ
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. ТАБЛИЦЯ КОРИСТУВАЧІВ (Для входу в систему)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// 3. ТАБЛИЦЯ ТВАРИНОК (Повністю під твою анкету "Шукаю дім")
model Pet {
  id            String   @id @default(uuid())
  name          String?  // Ім'я
  type          String   // Хто це (Песик / Котик / Інше)
  gender        String   // Стать (Хлопчик / Дівчинка)
  age           String   // Вік
  sterilization String   // Стерилізація
  vaccination   String   // Вакцинація
  region        String   // Область
  city          String   // Місто / Село
  description   String   @db.Text // Опис (зробили Text, щоб влізла довга історія)
  photos        String?  @db.Text // Тепер це множина (photos), і тут буде список
  
  // Системні поля для твоєї адмінки
  status        String   @default("pending") // pending - на перевірці, published - на сайті
  createdAt     DateTime @default(now())     // Дата подачі заявки
}