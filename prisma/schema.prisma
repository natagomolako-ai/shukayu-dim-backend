// 1. НАЛАШТУВАННЯ ПІДКЛЮЧЕННЯ
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. ТАБЛИЦЯ КОРИСТУВАЧІВ (Для входу в систему)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// 3. ТАБЛИЦЯ ТВАРИНОК (Повністю під твою анкету "Шукаю дім")
model Pet {
  id            String        @id @default(uuid())
  name          String?
  type          String
  gender        String
  age           String
  sterilization String
  vaccination   String
  region        String
  city          String
  description   String
  photos        String        @default("[]")
  status        String        @default("pending")
  category      String        @default("adoption") // "adoption" або "lost"
  createdAt     DateTime      @default(now())
  applications  Application[] // 🔥 ОНОВЛЕНО: зв'язок із заявками від людей
}

// 🔥 4. ТАБЛИЦЯ ЗАЯВОК ВІД ПОТЕНЦІЙНИХ ВЛАСНИКІВ 🔥
model Application {
  id        Int      @id @default(autoincrement())
  petId     String   // ID тваринки, яку хочуть забрати
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String   // Ім'я заявника
  surname   String   // Прізвище заявника
  city      String   // Місто проживання людини
  phone     String   // Номер телефону для зв'язку
  comment   String?  // Зручний час або нік в соцмережах (String?, бо поле може бути порожнім)
  createdAt DateTime @default(now())
}