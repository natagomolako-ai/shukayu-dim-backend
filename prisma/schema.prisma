// Це твій файл конфігурації бази даних

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Модель користувача (вона у тебе вже є, просто перевір)
model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  pets     Pet[]   // Зв'язок: один користувач може створити багато оголошень
}

// НОВА МОДЕЛЬ: Оголошення про тваринку
model Pet {
  id          Int      @id @default(autoincrement())
  name        String   // Кличка
  type        String   // Песик чи Котик
  age         String   // Цуценя, Дорослий тощо
  gender      String   // Хлопчик чи Дівчинка
  location    String   // Місто/Район
  description String   @db.Text // Історія тваринки
  imageUrl    String?  // Посилання на фото
  status      String   @default("PENDING") // PENDING - чекає на твою перевірку, APPROVED - на сайті
  userId      Int      // ID того, хто створив
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}