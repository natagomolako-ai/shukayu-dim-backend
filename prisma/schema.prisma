generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Модель користувача
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) // ДОДАНО: тепер база не буде "сваритися"
  pets      Pet[]    // Зв'язок: один користувач може мати багато оголошень
}

// Модель оголошення про тваринку
model Pet {
  id          Int      @id @default(autoincrement())
  name        String   // Кличка
  type        String   // Песик чи Котик
  age         String   // Цуценя, Дорослий тощо
  gender      String   // Хлопчик чи Дівчинка
  location    String   // Місто/Район
  description String   @db.Text // Історія тваринки (Text для довгих описів)
  imageUrl    String?  // Посилання на фото (може бути порожнім)
  status      String   @default("PENDING") // Чекає на перевірку менеджером
  userId      Int      // Хто створив
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}